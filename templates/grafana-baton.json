{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Throughput (per node)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(baton_requests_total[1m])",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Error Rate (per node)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "baton_error_rate",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      }
    },
    {
      "title": "Latency Percentiles (per node)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "baton_latency_p50_ms",
          "legendFormat": "{{node}} p50",
          "refId": "A"
        },
        {
          "expr": "baton_latency_p95_ms",
          "legendFormat": "{{node}} p95",
          "refId": "B"
        },
        {
          "expr": "baton_latency_p99_ms",
          "legendFormat": "{{node}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "title": "Active Connections (per node)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "baton_active_connections",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests Failed (per node)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "baton_requests_failed",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "title": "Telemetry Class Breakdown",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "baton_requests_total",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["baton", "circuit", "observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Baton Circuit Dashboard",
  "uid": "baton-circuit",
  "version": 1
}
