          "error_data": {
            "exit_code": "1"
          }
        },
        {
          "name": "FileNotFoundError",
          "condition": "Required configuration files or directories not found",
          "error_type": "FileNotFoundError",
          "error_data": {
            "exit_code": "1"
          }
        },
        {
          "name": "KeyboardInterrupt",
          "condition": "User interrupts with Ctrl+C",
          "error_type": "KeyboardInterrupt",
          "error_data": {
            "exit_code": "130"
          }
        }
      ],
      "preconditions": [],
      "postconditions": [
        "Returns 0 on successful command execution",
        "Returns 1 on command parsing errors, validation errors, or missing command",
        "Returns 130 on KeyboardInterrupt"
      ],
      "idempotent": false,
      "side_effects": [
        "Prints help or error messages to stdout/stderr",
        "Invokes subcommand handlers that may modify filesystem, start processes, or make network calls"
      ],
      "structured_side_effects": [
        {
          "kind": "writes_file",
          "target": "Circuit configuration files",
          "description": "Via subcommand handlers"
        },
        {
          "kind": "network_call",
          "target": "Deployment providers",
          "description": "Via deploy commands"
        },
        {
          "kind": "logging",
          "target": "stdout/stderr",
          "description": "Help, status, and error messages"
        }
      ],
      "performance_budget": null
    },
