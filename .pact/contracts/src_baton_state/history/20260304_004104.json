{
  "component_id": "src_baton_state",
  "name": "Baton State Persistence",
  "description": "Manages state persistence for Baton by handling the .baton/ directory structure, saving/loading CircuitState as JSON, and managing JSONL append/read operations for logs and tracking data.",
  "version": 1,
  "types": [
    {
      "name": "PathLike",
      "kind": "union",
      "fields": [],
      "item_type": "",
      "variants": [],
      "inner_types": [
        "str",
        "Path"
      ],
      "description": "Accepts either string or Path object for directory paths"
    }
  ],
  "functions": [
    {
      "name": "ensure_baton_dir",
      "description": "Creates the .baton/ directory if it doesn't exist and returns its path",
      "inputs": [
        {
          "name": "project_dir",
          "type_ref": "str | Path",
          "required": true,
          "default": "",
          "description": "Base project directory where .baton/ should be created",
          "validators": []
        }
      ],
      "output_type": "Path",
      "error_cases": [
        {
          "name": "OSError",
          "condition": "Insufficient permissions or invalid path",
          "error_type": "OSError",
          "error_data": {}
        }
      ],
      "preconditions": [],
      "postconditions": [
        ".baton/ directory exists at project_dir/.baton/",
        "All parent directories are created if needed",
        "Returns Path object pointing to .baton/ directory"
      ],
      "idempotent": false,
      "side_effects": [
        "Creates directory on filesystem if it doesn't exist"
      ],
      "structured_side_effects": [
        {
          "kind": "writes_file",
          "target": "project_dir/.baton/",
          "description": "Creates directory structure"
        }
      ],
      "performance_budget": null
    },
    {
      "name": "save_state",
      "description": "Saves CircuitState object to .baton/state.json as formatted JSON",
      "inputs": [
        {
          "name": "state",
          "type_ref": "CircuitState",
          "required": true,
          "default": "",
          "description": "CircuitState object to persist",
          "validators": []
        },
        {
          "name": "project_dir",
          "type_ref": "str | Path",
          "required": true,
          "default": "",
          "description": "Base project directory",
          "validators": []
        }
      ],
      "output_type": "None",
      "error_cases": [
        {
          "name": "OSError",
          "condition": "File write permission denied or disk full",
          "error_type": "OSError",
          "error_data": {}
        },
        {
          "name": "AttributeError",
          "condition": "state object doesn't have model_dump() method",
          "error_type": "AttributeError",
          "error_data": {}
        },
        {
          "name": "TypeError",
          "condition": "state.model_dump() returns non-serializable data",
          "error_type": "TypeError",
          "error_data": {}
        }
      ],
      "preconditions": [
        "state must be a valid CircuitState with model_dump() method"
      ],
      "postconditions": [
        ".baton/state.json exists with indented JSON content",
        "File content is the result of state.model_dump() serialized"
      ],
      "idempotent": false,
      "side_effects": [
        "Creates/overwrites .baton/state.json file"
      ],
      "structured_side_effects": [
        {
          "kind": "writes_file",
          "target": "project_dir/.baton/state.json",
          "description": "Writes serialized CircuitState with 2-space indentation"
        }
      ],
      "performance_budget": null
    },
    {
      "name": "load_state",
      "description": "Loads CircuitState from .baton/state.json or returns None if file doesn't exist",
      "inputs": [
        {
          "name": "project_dir",
          "type_ref": "str | Path",
          "required": true,
          "default": "",
          "description": "Base project directory",
          "validators": []
        }
      ],
      "output_type": "CircuitState | None",
      "error_cases": [
        {
          "name": "JSONDecodeError",
          "condition": "state.json contains invalid JSON",
          "error_type": "json.JSONDecodeError",
          "error_data": {}
        },
        {
          "name": "ValidationError",
          "condition": "JSON doesn't match CircuitState schema",
          "error_type": "ValidationError",
          "error_data": {}
        },
        {
          "name": "OSError",
          "condition": "File exists but cannot be read",
          "error_type": "OSError",
          "error_data": {}
        }
      ],
      "preconditions": [],
      "postconditions": [
        "Returns CircuitState instance if file exists and is valid JSON",
        "Returns None if file doesn't exist"
      ],
      "idempotent": false,
      "side_effects": [],
      "structured_side_effects": [
        {
          "kind": "reads_file",
          "target": "project_dir/.baton/state.json",
          "description": "Reads and parses JSON state file"
        }
      ],
      "performance_budget": null
    },
    {
      "name": "clear_state",
      "description": "Removes the state.json file if it exists",
      "inputs": [
        {
          "name": "project_dir",
          "type_ref": "str | Path",
          "required": true,
          "default": "",
          "description": "Base project directory",
          "validators": []
        }
      ],
      "output_type": "None",
      "error_cases": [
        {
          "name": "OSError",
          "condition": "File exists but cannot be deleted due to permissions",
          "error_type": "OSError",
          "error_data": {}
        }
      ],
      "preconditions": [],
      "postconditions": [
        ".baton/state.json does not exist after function completes"
      ],
      "idempotent": false,
      "side_effects": [
        "Deletes .baton/state.json if present"
      ],
      "structured_side_effects": [
        {
          "kind": "writes_file",
          "target": "project_dir/.baton/state.json",
          "description": "Deletes state file"
        }
      ],
      "performance_budget": null
    },
    {
      "name": "append_jsonl",
      "description": "Appends a single JSON object as a line to a JSONL file in .baton/ directory",
      "inputs": [
        {
          "name": "project_dir",
          "type_ref": "str | Path",
          "required": true,
          "default": "",
          "description": "Base project directory",
          "validators": []
        },
        {
          "name": "filename",
          "type_ref": "str",
          "required": true,
          "default": "",
          "description": "Name of JSONL file within .baton/ directory",
          "validators": []
        },
        {
          "name": "data",
          "type_ref": "dict",
          "required": true,
          "default": "",
          "description": "Dictionary to serialize and append as JSON line",
          "validators": []
        }
      ],
      "output_type": "None",
      "error_cases": [
        {
          "name": "OSError",
          "condition": "Cannot write to file due to permissions or disk space",
          "error_type": "OSError",
          "error_data": {}
        },
        {
          "name": "TypeError",
          "condition": "data contains non-JSON-serializable objects",
          "error_type": "TypeError",
          "error_data": {}
        }
      ],
      "preconditions": [],
      "postconditions": [
        "data is appended as JSON followed by newline to .baton/<filename>",
        ".baton/ directory exists"
      ],
      "idempotent": false,
      "side_effects": [
        "Creates or appends to .baton/<filename>"
      ],
      "structured_side_effects": [
        {
          "kind": "writes_file",
          "target": "project_dir/.baton/<filename>",
          "description": "Appends JSON line to file"
        }
      ],
      "performance_budget": null
    },
    {
      "name": "read_jsonl",
      "description": "Reads JSONL file from .baton/ directory, optionally returning only the last N lines",
      "inputs": [
        {
          "name": "project_dir",
          "type_ref": "str | Path",
          "required": true,
          "default": "",
          "description": "Base project directory",
          "validators": []
        },
        {
          "name": "filename",
          "type_ref": "str",
          "required": true,
          "default": "",
          "description": "Name of JSONL file within .baton/ directory",
          "validators": []
        },
        {
          "name": "last_n",
          "type_ref": "int | None",
          "required": false,
          "default": "None",
          "description": "If specified, return only the last N lines",
          "validators": []
        }
      ],
      "output_type": "list[dict]",
      "error_cases": [
        {
          "name": "JSONDecodeError",
          "condition": "A line contains invalid JSON",
          "error_type": "json.JSONDecodeError",
          "error_data": {}
        },
        {
          "name": "OSError",
          "condition": "File exists but cannot be read",
          "error_type": "OSError",
          "error_data": {}
        }
      ],
      "preconditions": [],
      "postconditions": [
        "Returns empty list if file doesn't exist",
        "Returns list of parsed JSON objects from non-empty lines",
        "If last_n is specified, returns at most last_n items",
        "Empty/whitespace lines are skipped"
      ],
      "idempotent": false,
      "side_effects": [],
      "structured_side_effects": [
        {
          "kind": "reads_file",
          "target": "project_dir/.baton/<filename>",
          "description": "Reads entire JSONL file"
        }
      ],
      "performance_budget": null
    }
  ],
  "dependencies": [
    "json",
    "pathlib",
    "baton.schemas"
  ],
  "dependency_contracts": {
    "baton.schemas": [
      "CircuitState"
    ]
  },
  "invariants": [
    "BATON_DIR constant is '.baton'",
    "STATE_FILE constant is 'state.json'",
    "All file operations use the .baton/ subdirectory within project_dir",
    "JSON serialization uses 2-space indentation for state files",
    "JSONL format: one JSON object per line with trailing newline"
  ],
  "requires": []
}